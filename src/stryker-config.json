{
  "stryker-config": {
    "project": "Betfair.csproj",
    "test-projects": ["./Betfair.Tests/Betfair.Tests.csproj"],
    "target-framework": "net10.0",
    "concurrency": 4,
    "mutation-level": "Standard",
    "mutate": [
      "Betfair/**/*.cs",
      "!Betfair/**/obj/**",
      "!Betfair/**/bin/**",
      "!Betfair/GlobalUsings.cs",
      "!Betfair/SerializerContext.cs"
    ],
    "reporters": ["dashboard", "progress"],
    "thresholds": {
      "high": 80,
      "low": 60,
      "break": 40
    }
  }
}
