{
  "stryker-config": {
    "project": "Betfair.csproj",
    "test-projects": ["./Betfair.Tests/Betfair.Tests.csproj"],
    "target-framework": "net10.0",
    "concurrency": 2,
    "mutation-level": "Standard",
    "mutate": [
      "**/*.cs",
      "!**/obj/**",
      "!**/bin/**",
      "!**/GlobalUsings.cs",
      "!**/SerializerContext.cs"
    ],
    "reporters": ["dashboard", "progress"],
    "thresholds": {
      "high": 80,
      "low": 60,
      "break": 40
    }
  }
}
